# ==========================================
# VANGUARD26 ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the values.
# Do NOT commit the actual .env file to Git!
# ==========================================

# Port for the Node.js Express server to listen on
PORT=3000

# CORS Whitelist Origin (production web client address or localhost)
# Used to restrict API access. Standard wildcard * is disabled in production.
ALLOWED_ORIGIN=http://localhost:3000

# Groq API Key
# Obtain an API key from Groq Console (https://console.groq.com/)
# Set this to enable dynamic Fan Co-Pilot and AI Operations Triage recommendations.
GROQ_API_KEY=your_groq_api_key_here

# Operations console passcode (hashed on load)
# Default code is 2026
OPS_PIN=2026
